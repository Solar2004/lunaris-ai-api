# Server
PORT=3000

# Provider API Keys (can add multiple keys separated by comma for fallback)
# Example: GROQ_API_KEY=key1,key2,key3
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
CODESTRAL_API_KEY=
GITHUB_TOKEN=
NVIDIA_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# Tracking
TRACKING_ENABLED=true
TRACKING_RESET_HOUR=0

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Alerts
ALERT_THRESHOLD_WARNING=75
ALERT_THRESHOLD_CRITICAL=90

# Logging
RUST_LOG=info,lunaris_ai_api=debug
